# ──────────────────────────────────────────────────────────────────────────────
# 5000 Tomorrow — Environment Variables
# Copy this file to .env.local and fill in values for local development.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Site ───────────────────────────────────────────────────────────────────────

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.5000tomorrow.com

# ── Analytics ─────────────────────────────────────────────────────────────────

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager Container ID (format: GTM-XXXXXXX) — optional if using GTM
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Meta Pixel ID (numeric string)
NEXT_PUBLIC_META_PIXEL_ID=0000000000000000

# Google Search Console site verification token
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Yandex verification (optional)
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ── CRM & Webhooks ────────────────────────────────────────────────────────────

# CRM webhook URL — receives POST with lead JSON on every apply submission
# Examples: GoHighLevel webhook, HubSpot webhook, Zapier/Make catch hook
CRM_WEBHOOK_URL=https://hooks.example.com/your-webhook-id

# API key for CRM authorization header (Bearer token)
CRM_API_KEY=your-crm-api-key

# Attorney referral webhook — can be the same as CRM_WEBHOOK_URL or separate
ATTORNEY_REFERRAL_WEBHOOK_URL=https://hooks.example.com/your-referral-webhook-id

# Contact form webhook
CONTACT_WEBHOOK_URL=https://hooks.example.com/your-contact-webhook-id

# ── Email ─────────────────────────────────────────────────────────────────────

# Resend API key — for transactional emails (confirmation, team notify)
# https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid API key — alternative to Resend
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address that receives new lead notifications
NOTIFY_EMAIL=team@5000tomorrow.com

# From address for applicant confirmation emails
CONFIRM_FROM_EMAIL=no-reply@5000tomorrow.com

# ── Database (optional — for persistent lead storage) ─────────────────────────

# PostgreSQL connection string (e.g., Neon, Supabase, PlanetScale)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Feature Flags ─────────────────────────────────────────────────────────────

# Set to 'true' to enable verbose API logging in production
# LOG_LEVEL=info

# ── External integrations (future) ────────────────────────────────────────────

# Twilio — for SMS confirmation to applicants
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+18885000050

# ── Build ─────────────────────────────────────────────────────────────────────

# Set to 'true' to enable @next/bundle-analyzer output
# ANALYZE=false
